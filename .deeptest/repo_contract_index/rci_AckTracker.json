      "postconditions": ["PacketNumbersToAck min raised"]
    },
    {
      "name": "QuicAckTrackerHasPacketsToAck",
      "signature": "BOOLEAN QuicAckTrackerHasPacketsToAck(const QUIC_ACK_TRACKER* Tracker)",
      "needs_connection": false,
      "inline": true,
      "returns": "!AlreadyWrittenAckFrame && PacketNumbersToAck size != 0"
    }
  ],
  "state_machine": {
    "states": ["Empty", "Receiving", "Written", "Acked"],
    "transitions": [
      {"from": "Empty", "to": "Receiving", "trigger": "AckPacket"},
      {"from": "Receiving", "to": "Written", "trigger": "AckFrameEncode"},
      {"from": "Written", "to": "Receiving", "trigger": "AckPacket(new)"},
      {"from": "Written", "to": "Acked", "trigger": "OnAckFrameAcked"},
      {"from": "Receiving", "to": "Acked", "trigger": "OnAckFrameAcked"},
      {"from": "Acked", "to": "Receiving", "trigger": "AckPacket(new)"},
      {"from": "Any", "to": "Empty", "trigger": "Reset"}
    ]
  }
